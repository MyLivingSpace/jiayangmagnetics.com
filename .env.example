# Contact form email forwarding
# -----------------------------
# Configure ONE provider: Resend (preferred) OR SMTP.

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=Jiayang Website <no-reply@your-domain.com>

# SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=Jiayang Website <no-reply@your-domain.com>
